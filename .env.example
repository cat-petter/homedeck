# HomeDeck environment overrides — copy to .env and edit (git-ignored).
# These override config.yaml. Use the HOMEDECK_ prefix with `__` for nesting.
# Loaded automatically by pydantic-settings when present in the repo root.

# Example overrides:
# HOMEDECK_SERVER__HOST=0.0.0.0
# HOMEDECK_SERVER__PORT=8080

# Point at a non-default config file:
# HOMEDECK_CONFIG_FILE=/etc/homedeck/config.yaml
