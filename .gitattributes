# Normalize line endings. Enforce LF for everything text by default.
* text=auto eol=lf

# Shell scripts and the systemd unit MUST stay LF.
*.sh text eol=lf
*.service text eol=lf

# Explicit text types (kept LF).
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Binary assets (never normalize).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
